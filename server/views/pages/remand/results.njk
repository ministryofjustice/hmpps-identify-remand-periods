
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/textarea/macro.njk" import govukTextarea %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/details/macro.njk" import govukDetails %}
{% from "govuk/components/warning-text/macro.njk" import govukWarningText %}
{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}
{% from "../../components/remand-table/macro.njk" import remandTable %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}

{% extends "../../partials/layout.njk" %}

{% set pageTitle = applicationName + " - Home" %}
{% set mainClasses = "app-container govuk-body" %}

{% block beforeContent %}
    {{ super() }}
    <nav>
        {% set backLink = model.backLink() %}
        {% if backLink %}
            {{ govukBackLink({
                text: "Back",
                href: backLink,
                attributes: { "data-qa": "back-link" }
            }) }}
        {% endif %}
    </nav>
{% endblock %}

{% block content %}

{% set helpText = "This will help our support team improve the accuracy of the remand tool." %}

{% if model.totalDays() > 0 %}
  {% set labelText = (
    "Explain why the remand to be applied is incorrect. "
    ~ helpText
  ) %}
{% else %}
  {% set labelText = (
    "Explain why there should be remand to be applied. "
    ~ helpText
  ) %}
{% endif %}

    {% if form.errors.length %}
        <div class="govuk-grid-row">
            <div class="govuk-grid-column-full">
                {{ govukErrorSummary({
          titleText: "There is a problem",
          errorList: form.errorList()
        }) }}
            </div>
        </div>
    {% elif model
            .mostImportantErrors()
            .length %}
        {% set errorBody %}
        <div class="govuk-error-summary__body">
            <p>There is information missing in NOMIS that could impact the remand time.</p>
            <ul class="govuk-list govuk-error-summary__list">
                {% for error in model.mostImportantErrors() %}
                    <li>
                        <p class="govuk-body">{{error.message}}</p>
                    </li>
                {% endfor %}
            </ul>
            <p class="govuk-!-margin-top-4">To ensure the remand time is calculated correctly, add the missing information in NOMIS, then <a href="">reload this page</a>.</p>
        </div>
        {% endset -%}

        {{ govukErrorSummary({
          titleText: "There is a problem",
          errorList: [],
          descriptionHtml: errorBody
    }) }}
    {% endif %}
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-full">
            <h1 class="govuk-heading-xl govuk-!-margin-bottom-4">
                <span class="govuk-caption-xl">Review remand</span>
                Check remand details for {{prisoner.firstName | title}} {{prisoner.lastName | title}}
            </h1>

            {% if model.changesNumberOfDays() %}
                {% set html %}
                    <h3 class="govuk-notification-banner__heading">The number of remand days recorded has changed</h3>
                    <p class="govuk-body">The number of remand days does not match what was originally recorded. Make sure the remand information is correct, before continuing.</p>
                {% endset %}

                {{ govukNotificationBanner({
                    html: html
                }) }}
            {% endif %}
        </div>
    </div>

    {% if  model.totalDays() > 0 %}
        {{ remandTable(model.remandTable, 'Remand periods to be applied') }}
    {% else %}
        <div class="govuk-grid-row govuk-!-margin-bottom-4">
            <div class="govuk-grid-column-three-quarters">
                <h2>No remand to be applied</h2>
                <p class="govuk-body">The remand tool has calculated that there is no remand to be applied</p>
            </div>
        </div>
    {% endif %}

    <div class="govuk-grid-row">
        <div class="govuk-grid-column-three-quarters">
            <p class="govuk-body"><a href="{{ model.detailedBreakdownLink() }}" class="govuk-link--no-visited-state">View full remand breakdown</a></p>
        </div>
    </div>

    <div class="govuk-grid-row">
        <div class="govuk-grid-column-full">
            {% if model
                .otherErrors()
                .length %}
                {% set unrelatedHtml %}
                <ul class="govuk-list">
                    {% for error in model.otherErrors() %}
                        <li>{{error.message}}</li>
                    {% endfor %}
                </ul>
                {% endset -%}
                {{ govukDetails({
                summaryText: "There are errors with nomis data that may be unrelated to the given relevant remand",
                html: unrelatedHtml
            }) }}
            {% endif %}
            {% if model
                .mostImportantErrors()
                .length == 0 %}
                <form class="form" method="post">
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}"/>
                    {% set commentHtml %}
                    {{ govukTextarea({
                    name: "comment",
                    id: "comment",
                    value: form.comment,
                    label: {
                        text: labelText
                    },
                    errorMessage: form.messageForField('comment')
                    }) }}
                    {% endset -%}

                    {{ govukRadios({
                name: "decision",
                fieldset: {
                    legend: {
                    text: "Confirm the remand to be applied is correct",
                    classes: "govuk-fieldset__legend--l"
                    }
                },
                errorMessage: form.messageForField('decision'),
                value: form.decision,
                items: [
                    {
                        value: "yes",
                        text: "Yes, the remand to be applied is correct"
                    },
                    {
                        value: "no",
                        text: "No, the remand to be applied is wrong",
                        conditional: {
                            html: commentHtml
                        }
                    }
                ]
                }) }}
                    <div>
                        <button class="govuk-button" data-module="govuk-button" name="submit">Confirm remand</button>
                        <a data-qa="cancel-link"
                           data-prevent-double-click="true" class="govuk-button govuk-!-margin-left-3 govuk-button--secondary no-js-hidden"
                           data-module="govuk-button"
                           href="{{ model.returnToAdjustments() }}">
                            Cancel
                        </a>
                    </div>
                </form>
            {% endif %}
        </div>
    </div>
{% endblock %}
